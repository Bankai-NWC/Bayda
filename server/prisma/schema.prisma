generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
}

enum Gender {
  MAN
  WOMAN
  UNISEX
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique @db.VarChar(128)
  passwordHash    String
  fullName        String
  phone           String    @unique @db.VarChar(20)
  isActivated     Boolean   @default(false)
  activationLink  String    @unique
  passwordResetToken PasswordResetToken?
  role            Role      @default(USER)
  sessions        Session[]
  addresses       Address[]
  orders          Order[]
  wishlist        Wishlist[]
  cart            Cart?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime @updatedAt
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Address {
  id          Int     @id @default(autoincrement())
  userId      Int
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  city        String
  street      String
  houseNumber String
  apartment   String?
  isDefault   Boolean @default(false)
}

model Order {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingCity        String
  shippingStreet      String
  shippingHouseNumber String
  shippingApartment   String?
  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id              Int            @id @default(autoincrement())
  orderId         Int
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId       Int
  productVariant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantity        Int            @default(1)
  priceAtPurchase Decimal        @db.Decimal(10, 2)
}

model Product {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique
  description String?
  variants    ProductVariant[]
  images      ProductImage[]
  gender      Gender           @default(UNISEX)
  sizeChart   SizeChart?
  materials   Material[]
  collectionId Int?
  collection  Collection?      @relation(fields: [collectionId], references: [id])
  categoryId  Int
  category    Category         @relation(fields: [categoryId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([slug])
}

model Material {
  id         Int     @id @default(autoincrement())
  productId  Int
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  percentage Float

  @@unique([productId, name])
}

model SizeChart {
  id        Int           @id @default(autoincrement())
  productId Int           @unique
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  entries   SizeEntry[]
}

model SizeEntry {
  id          Int           @id @default(autoincrement())
  sizeChartId Int
  sizeChart   SizeChart     @relation(fields: [sizeChartId], references: [id], onDelete: Cascade)
  size        String
  measurements Measurement[]
}

model Measurement {
  id          Int       @id @default(autoincrement())
  sizeEntryId Int
  sizeEntry   SizeEntry @relation(fields: [sizeEntryId], references: [id], onDelete: Cascade)
  name        String
  value       Float
  unit        String    @default("cm")
}

model ProductVariant {
  id         Int            @id @default(autoincrement())
  productId  Int
  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  size       String?
  colorId    Int?
  color      Color?         @relation(fields: [colorId], references: [id])
  price      Decimal        @db.Decimal(10, 2)
  salePrice  Decimal?       @db.Decimal(10, 2)
  sku        String         @unique
  stock      Int            @default(0)
  images     VariantImage[]
  orderItems OrderItem[]
  wishlist   Wishlist[] 
  cartItems  CartItem[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model ProductImage {
  id        Int             @id @default(autoincrement())
  productId Int?
  product   Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  publicId  String
  url       String
  isMain    Boolean         @default(false)
  order     Int             @default(0)
  variants  VariantImage[]
}

model VariantImage {
  id        Int            @id @default(autoincrement())
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  imageId   Int
  image     ProductImage   @relation(fields: [imageId], references: [id], onDelete: Cascade)
  order     Int            @default(0)

  @@unique([variantId, imageId])
}

model Color {
  id        Int    @id @default(autoincrement())
  name      String @unique
  hexCode   String?
  variants  ProductVariant[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  slug     String    @unique
  sizes    CategorySize[]
  products Product[]
}

model Collection {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  products    Product[]
}

model CategorySize {
  id         Int       @id @default(autoincrement())
  categoryId Int
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  size       String
  
  @@unique([categoryId, size])
}

model Wishlist {
  id        Int            @id @default(autoincrement())
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, variantId])
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int?       @unique
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?    @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int            @id @default(autoincrement())
  cartId    Int
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int            @default(1)

  @@unique([cartId, variantId])
}

